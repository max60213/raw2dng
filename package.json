{
  "name": "raw2dng",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config apps/web/vite.config.ts",
    "build": "vite build --config apps/web/vite.config.ts",
    "build:wasm": "echo 'source .tools/emsdk/emsdk_env.sh && bash packages/libraw-wasm/scripts/build-wasm.sh'",
    "inspect:roundtrip": "vite-node --config vitest.config.ts scripts/generate-roundtrip.ts",
    "preview": "vite preview --config apps/web/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "lint": "tsc --noEmit",
    "check": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^24.1.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.1"
  }
}
